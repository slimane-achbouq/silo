# Neon PostgreSQL — pooled connection, used by Prisma Client (driver adapter) at runtime
DATABASE_URL="postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Neon PostgreSQL — direct (non-pooled) connection, used by the Prisma CLI for migrations
DIRECT_URL="postgresql://user:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require"

# Password for the seeded demo user (prisma/seed.ts). Override this for any non-local seed target;
# falls back to "12345678" for local dev if unset.
DEMO_USER_PASSWORD="12345678"

# NextAuth v5 — secret used to sign/encrypt JWTs and session cookies (generate with `npx auth secret`)
AUTH_SECRET=

# GitHub OAuth app credentials (github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
